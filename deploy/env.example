# ============================================================
# AI Museum Tagger — Konfiguration
# Kopiere diese Datei zu .env und fülle alle Werte aus.
# ============================================================

# --- DOMAIN ---
DOMAIN=meinmuseum.de

# --- SERVER IPs ---
HETZNER_IP=1.2.3.4
SCALEWAY_IP=5.6.7.8

# --- LLM API ---
# Beliebiger String — muss auf beiden Servern gleich sein
LLM_API_KEY=sk-dein-key

# --- N8N ---
# openssl rand -hex 32
N8N_ENCRYPTION_KEY=

# --- SEARXNG ---
# openssl rand -hex 32
SEARXNG_SECRET_KEY=

# --- SEATABLE ---
SEATABLE_ADMIN_EMAIL=admin@example.com
SEATABLE_ADMIN_PASSWORD=
SEATABLE_DB_PASSWORD=
SEATABLE_REDIS_PASSWORD=
# openssl rand -hex 32
SEATABLE_JWT_KEY=

# --- HUGGINGFACE (für Modell-Downloads auf Scaleway) ---
HF_TOKEN=
